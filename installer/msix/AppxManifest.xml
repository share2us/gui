<?xml version="1.0" encoding="utf-8"?>
<!--
  MSIX package manifest for Share2Us. Packages the full-trust Win32 app
  (share2us-gui.exe) and declares a Windows Share Target so S2u appears in the
  Windows Share sheet (Snip & Sketch's "Share", the Photos app, Explorer's
  "Share", etc.) for images, files, and text.

  Version is stamped at build time (see the release workflow's installer job,
  which builds this MSIX and publishes it as a standalone asset).

  DISTRIBUTION = Microsoft Store. Setup.exe no longer sideloads this MSIX (that
  required trusting a self-signed cert into LocalMachine\Root — a malware pattern
  that got flagged; see installer/DISTRIBUTION.md). Before Store submission, the
  Identity below (Name + Publisher) MUST be replaced with the values Partner
  Center assigns to the reserved app (Product identity page): e.g.
  Name="<StoreReservedName>", Publisher="CN=<your-store-publisher-id>". The Store
  then re-signs the package with a trusted cert.
-->
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap rescap">

  <!-- Identity assigned by Partner Center (reserved product "Share2Us",
       Store ID 9NFR4MMM7RJ8). Must match exactly or Store ingestion rejects the
       package. The Store re-signs with its trusted cert, so this MSIX is uploaded
       UNSIGNED (do not signtool-sign it with the self-signed installer cert). -->
  <Identity
    Name="Share2Us.Share2us"
    Publisher="CN=8F6CFF38-67FC-45C0-9A09-AF6CCD6B9EC9"
    Version="1.0.0.0"
    ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>Share2Us</DisplayName>
    <PublisherDisplayName>Share2Us</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.22621.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Applications>
    <Application Id="Share2Us" Executable="share2us-gui.exe" EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="Share2Us"
        Description="Share files, screenshots, and text with Share2Us"
        BackgroundColor="transparent"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png">
        <uap:DefaultTile Wide310x150Logo="Assets\Wide310x150Logo.png" Square71x71Logo="Assets\Square71x71Logo.png" Square310x310Logo="Assets\Square310x310Logo.png" />
      </uap:VisualElements>
      <Extensions>
        <!-- Windows Share Target: makes S2u a destination in the Share sheet. -->
        <uap:Extension Category="windows.shareTarget">
          <uap:ShareTarget>
            <uap:SupportedFileTypes>
              <uap:SupportsAnyFileType />
            </uap:SupportedFileTypes>
            <uap:DataFormat>Bitmap</uap:DataFormat>
            <uap:DataFormat>StorageItems</uap:DataFormat>
            <uap:DataFormat>Text</uap:DataFormat>
            <uap:DataFormat>Uri</uap:DataFormat>
          </uap:ShareTarget>
        </uap:Extension>
      </Extensions>
    </Application>
  </Applications>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>
</Package>
